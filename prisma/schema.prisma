// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Item {
  id        Int      @id @default(autoincrement())
  title     String
  createdAt DateTime @default(now())
}

enum CoverLetterSection {
  GROWTH_PROCESS
  PERSONALITY
  CAREER_STRENGTH
  MOTIVATION_ASPIRATION
}

enum RecommendSection {
  PROFILE
  JOB
  EDUCATION
  CAREER
  ACTIVITY
  CERTIFICATION
}

model ChatSession {
  id        String      @id @default(uuid())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  states    ChatState[]
  recommendStates RecommendState[]
  customCoverLetterSets CustomCoverLetterSet[]
  customCoverLetterChatStates CustomCoverLetterChatState[]
}

model ChatState {
  id         Int                 @id @default(autoincrement())
  sessionId  String
  section    CoverLetterSection
  summary    String              @default("")
  finalDraft String              @default("")
  isComplete Boolean             @default(false)
  updatedAt  DateTime            @updatedAt

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, section])
}

model RecommendState {
  id               Int              @id @default(autoincrement())
  sessionId        String
  section          RecommendSection
  accumulatedInput String           @default("")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, section])
}

model CustomCoverLetterSet {
  id         Int      @id @default(autoincrement())
  sessionId  String
  companyName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  session   ChatSession                 @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questions CustomCoverLetterQuestion[]

  @@index([sessionId])
}

model CustomCoverLetterQuestion {
  id                Int      @id @default(autoincrement())
  setId             Int
  order             Int
  title             String
  hasCharacterLimit Boolean  @default(false)
  characterLimit    Int?
  systemPrompt      String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  set        CustomCoverLetterSet         @relation(fields: [setId], references: [id], onDelete: Cascade)
  chatStates CustomCoverLetterChatState[]

  @@index([setId])
}

model CustomCoverLetterChatState {
  id         Int      @id @default(autoincrement())
  sessionId  String
  questionId Int
  summary    String   @default("")
  finalDraft String   @default("")
  isComplete Boolean  @default(false)
  updatedAt  DateTime @updatedAt

  session  ChatSession               @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question CustomCoverLetterQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId])
  @@index([questionId])
}

model AccessCode {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  payload   Json
  createdAt DateTime @default(now())
}

model RecruitmentPosting {
  id              Int      @id @default(autoincrement())
  recrutPblntSn   Int      @unique
  instNm          String   @default("")
  recrutPbancTtl  String   @default("")
  recrutSeNm      String   @default("")
  aplyQlfcCn      String   @default("")
  prefCn          String   @default("")
  pbancBgngYmd    String?
  pbancEndYmd     String?
  ongoingYn       String?
  isActive        Boolean  @default(true)
  isOngoing       Boolean  @default(true)
  ncsCdNmLst      String   @default("")
  hireTypeNmLst   String   @default("")
  workRgnNmLst    String   @default("")
  acbgCondNmLst   String   @default("")
  ncsCdNmList     String[] @default([])
  hireTypeNmList  String[] @default([])
  workRgnNmList   String[] @default([])
  acbgCondNmList  String[] @default([])
  searchText      String   @default("")
  raw             Json
  lastSeenAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive, isOngoing])
  @@index([pbancEndYmd])
  @@index([recrutSeNm])
  @@index([lastSeenAt])
  @@index([workRgnNmList], type: Gin)
  @@index([ncsCdNmList], type: Gin)
  @@index([hireTypeNmList], type: Gin)
  @@index([acbgCondNmList], type: Gin)
}
